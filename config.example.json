{
  "ha": {
    "url": "http://homeassistant.local:8123",
    "token": "your_long_lived_access_token_here",
    "verify_ssl": true,
    "timeout": 30
  },
  "llm": {
    "provider": "anthropic",
    "api_key": "your_api_key_here",
    "model": "claude-sonnet-4-6",
    "base_url": null,
    "max_tokens": 8192,
    "temperature": 0.3
  },
  "backup": {
    "max_versions": 10,
    "backup_dir": "./backup/archives"
  },
  "knowledge": {
    "cache_dir": "./knowledge/cache",
    "cache_ttl_days": 7
  }
}
